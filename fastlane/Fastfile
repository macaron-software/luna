default_platform(:ios)

# ASC API key (no password needed)
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"] || "48GLJZYX5K",
    issuer_id: ENV["ASC_ISSUER_ID"] || "69a6de74-3cdf-47e3-e053-5b8c7c11a4d1",
    key_filepath: ENV["ASC_KEY_FILEPATH"] || "#{Dir.home}/.appstoreconnect/private_keys/AuthKey_48GLJZYX5K.p8",
    in_house: false
  )
end

# ─── iOS ─────────────────────────────────────────────────────────────────────

platform :ios do

  desc "Build Rust core for iOS device (arm64)"
  lane :build_rust do
    sh "cd #{ENV['PWD']} && IPHONEOS_DEPLOYMENT_TARGET=16.0 cargo build --target aarch64-apple-ios --release -p luna-core"
    sh "cp #{ENV['PWD']}/target/aarch64-apple-ios/release/libluna_core.a #{ENV['PWD']}/ios-app/LunaApp/Generated/libluna_core.a"
    UI.success "Rust core built for aarch64-apple-ios"
  end

  desc "Archive and export IPA for App Store"
  lane :build do
    build_rust

    gym(
      project: "ios-app/LunaApp.xcodeproj",
      scheme: "LunaApp",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        teamID: "P36X572LL9",
        signingStyle: "manual",
        signingCertificate: "Apple Distribution",
        provisioningProfiles: {
          "com.macaron.luna" => "LUNA App Store Distribution"
        }
      },
      output_directory: "/tmp/fastlane_build",
      output_name: "LUNA.ipa",
      clean: false,
      xcargs: "IPHONEOS_DEPLOYMENT_TARGET=16.0 CODE_SIGN_STYLE=Manual DEVELOPMENT_TEAM=P36X572LL9 CODE_SIGN_IDENTITY='Apple Distribution' PROVISIONING_PROFILE_SPECIFIER='LUNA App Store Distribution'"
    )
    UI.success "IPA exported to /tmp/fastlane_build/LUNA.ipa"
  end

  desc "Upload IPA to App Store Connect (TestFlight)"
  lane :upload_testflight do
    api_key = asc_api_key

    pilot(
      api_key: api_key,
      ipa: "/tmp/fastlane_build/LUNA.ipa",
      skip_waiting_for_build_processing: true,
      changelog: "Privacy-first cycle tracking. AES-256 encryption. No cloud. No tracking."
    )
  end

  desc "Upload metadata and screenshots to App Store Connect"
  lane :upload_metadata do
    api_key = asc_api_key

    deliver(
      api_key: api_key,
      ipa: "/tmp/LunaApp_export/LUNA.ipa",
      submit_for_review: false,
      automatic_release: false,
      force: true,
      skip_binary_upload: true,
      metadata_path: "./fastlane/metadata/ios",
      screenshots_path: "./fastlane/screenshots/ios",
      precheck_include_in_app_purchases: false
    )
  end

  desc "Full release: build + upload to TestFlight"
  lane :release do
    build
    upload_testflight
    UI.success "iOS v#{get_version_number(xcodeproj: 'ios-app/LunaApp.xcodeproj')} uploaded to TestFlight!"
  end

  desc "Upload already-built IPA to App Store (shortcut)"
  lane :upload do
    api_key = asc_api_key
    upload_to_app_store(
      api_key: api_key,
      ipa: "/tmp/LunaApp_export/LUNA.ipa",
      submit_for_review: false,
      skip_metadata: true,
      skip_screenshots: true,
      force: true
    )
  end

end

# ─── Android ─────────────────────────────────────────────────────────────────

platform :android do

  desc "Build signed AAB"
  lane :build do
    gradle(
      project_dir: "android-app",
      task: "bundle",
      build_type: "Release",
      properties: {
        "android.injected.signing.store.file" => File.expand_path("android-app/keystore/luna-release.jks"),
        "android.injected.signing.store.password" => ENV["ANDROID_STORE_PASSWORD"] || "luna_store_2026",
        "android.injected.signing.key.alias" => "luna",
        "android.injected.signing.key.password" => ENV["ANDROID_KEY_PASSWORD"] || "luna_store_2026"
      }
    )
    UI.success "AAB built: android-app/app/build/outputs/bundle/release/app-release.aab"
  end

  desc "Upload AAB to Google Play (internal track, no assets)"
  lane :upload_internal do
    supply(
      package_name: "app.luna",
      aab: "android-app/app/build/outputs/bundle/release/app-release.aab",
      track: "internal",
      json_key: ENV["GOOGLE_PLAY_JSON_KEY"] || "fastlane/google-play-key.json",
      release_status: "draft",
      skip_upload_metadata: false,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      metadata_path: "fastlane/metadata/android"
    )
  end

  desc "Upload only metadata + screenshots (no binary)"
  lane :upload_store_assets do
    supply(
      package_name: "app.luna",
      track: "internal",
      json_key: ENV["GOOGLE_PLAY_JSON_KEY"] || "fastlane/google-play-key.json",
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_metadata: false,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      metadata_path: "fastlane/metadata/android"
    )
  end

  desc "Full release: build + upload AAB + metadata + screenshots to internal track"
  lane :release do
    build
    upload_internal
    UI.success "Android AAB + store assets uploaded to Play Store internal track!"
  end

  desc "Upload already-built AAB to Play Store (shortcut)"
  lane :upload do
    supply(
      package_name: "app.luna",
      aab: "android-app/app/build/outputs/bundle/release/app-release.aab",
      track: "internal",
      json_key: ENV["GOOGLE_PLAY_JSON_KEY"] || "fastlane/google-play-key.json",
      release_status: "draft",
      metadata_path: "fastlane/metadata/android"
    )
  end

end
