<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/lock_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <!-- Logo -->
    <ImageView
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/ic_luna_moon"
        android:importantForAccessibility="no"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"
        android:importantForAccessibility="yes"
        android:accessibilityHeading="true" />

    <!-- Message d'erreur -->
    <TextView
        android:id="@+id/error_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@android:color/holo_red_light"
        android:gravity="center"
        android:visibility="invisible"
        android:layout_marginBottom="16dp"
        android:accessibilityLiveRegion="polite" />

    <!-- Indicateurs PIN (6 points) -->
    <LinearLayout
        android:id="@+id/pin_dots_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <View android:id="@+id/dot1" android:layout_width="14dp" android:layout_height="14dp"
            android:layout_margin="6dp" android:background="@android:color/darker_gray" />
        <View android:id="@+id/dot2" android:layout_width="14dp" android:layout_height="14dp"
            android:layout_margin="6dp" android:background="@android:color/darker_gray" />
        <View android:id="@+id/dot3" android:layout_width="14dp" android:layout_height="14dp"
            android:layout_margin="6dp" android:background="@android:color/darker_gray" />
        <View android:id="@+id/dot4" android:layout_width="14dp" android:layout_height="14dp"
            android:layout_margin="6dp" android:background="@android:color/darker_gray" />
        <View android:id="@+id/dot5" android:layout_width="14dp" android:layout_height="14dp"
            android:layout_margin="6dp" android:background="@android:color/darker_gray" />
        <View android:id="@+id/dot6" android:layout_width="14dp" android:layout_height="14dp"
            android:layout_margin="6dp" android:background="@android:color/darker_gray" />

    </LinearLayout>

    <!-- Section PIN (visible par défaut) -->
    <LinearLayout
        android:id="@+id/pin_section"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Rangée 1-2-3 -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btn1" android:layout_width="72dp" android:layout_height="72dp" android:text="1" android:textSize="22sp" android:layout_margin="4dp" />
            <Button android:id="@+id/btn2" android:layout_width="72dp" android:layout_height="72dp" android:text="2" android:textSize="22sp" android:layout_margin="4dp" />
            <Button android:id="@+id/btn3" android:layout_width="72dp" android:layout_height="72dp" android:text="3" android:textSize="22sp" android:layout_margin="4dp" />
        </LinearLayout>
        <!-- Rangée 4-5-6 -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btn4" android:layout_width="72dp" android:layout_height="72dp" android:text="4" android:textSize="22sp" android:layout_margin="4dp" />
            <Button android:id="@+id/btn5" android:layout_width="72dp" android:layout_height="72dp" android:text="5" android:textSize="22sp" android:layout_margin="4dp" />
            <Button android:id="@+id/btn6" android:layout_width="72dp" android:layout_height="72dp" android:text="6" android:textSize="22sp" android:layout_margin="4dp" />
        </LinearLayout>
        <!-- Rangée 7-8-9 -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btn7" android:layout_width="72dp" android:layout_height="72dp" android:text="7" android:textSize="22sp" android:layout_margin="4dp" />
            <Button android:id="@+id/btn8" android:layout_width="72dp" android:layout_height="72dp" android:text="8" android:textSize="22sp" android:layout_margin="4dp" />
            <Button android:id="@+id/btn9" android:layout_width="72dp" android:layout_height="72dp" android:text="9" android:textSize="22sp" android:layout_margin="4dp" />
        </LinearLayout>
        <!-- Rangée *-0-⌫ -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
            <View android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="4dp" />
            <Button android:id="@+id/btn0" android:layout_width="72dp" android:layout_height="72dp" android:text="0" android:textSize="22sp" android:layout_margin="4dp" />
            <Button android:id="@+id/btnDelete" android:layout_width="72dp" android:layout_height="72dp" android:text="⌫" android:textSize="22sp" android:layout_margin="4dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
